{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "ls": "allow",
      "ls *": "allow",
      "pwd": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "file *": "allow",
      "stat *": "allow",
      "du *": "allow",
      "df *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "cat *~/.ssh/*": "deny",
      "cat *~/.gnupg/*": "deny",
      "cat *~/.aws/*": "deny",
      "head *~/.ssh/*": "deny",
      "head *~/.gnupg/*": "deny",
      "head *~/.aws/*": "deny",
      "tail *~/.ssh/*": "deny",
      "tail *~/.gnupg/*": "deny",
      "tail *~/.aws/*": "deny",
      "grep *~/.ssh/*": "deny",
      "grep *~/.gnupg/*": "deny",
      "grep *~/.aws/*": "deny",
      "rg *~/.ssh/*": "deny",
      "rg *~/.gnupg/*": "deny",
      "rg *~/.aws/*": "deny",
      "git status": "allow",
      "git status *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git show": "allow",
      "git show *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git blame": "allow",
      "git blame *": "allow",
      "git rev-parse *": "allow",
      "git checkout*": "deny",
      "git switch*": "deny",
      "git add*": "deny",
      "git commit*": "deny",
      "git push*": "deny",
      "git pull*": "deny",
      "git fetch*": "deny",
      "git merge*": "deny",
      "git rebase*": "deny",
      "git reset*": "deny",
      "git clean*": "deny",
      "git restore*": "deny",
      "git rm*": "deny",
      "git mv*": "deny",
      "git tag*": "deny",
      "git stash*": "deny",
      "git branch *": "deny",
      "git worktree*": "deny",
      "git cherry-pick*": "deny",
      "git revert*": "deny",
      "git init*": "deny",
      "git config*": "deny",
      "git remote *": "deny",
      "gh pr *": "deny",
      "gh issue *": "deny",
      "sudo *": "deny",
      "sudo": "deny",
      "rm -rf *": "deny",
      "rm -fr *": "deny",
      "rm -r *": "deny",
      "rm -f *": "deny",
      "chmod *": "deny",
      "chown *": "deny",
      "chgrp *": "deny",
      "dd *": "deny",
      "mkfs*": "deny",
      "shutdown*": "deny",
      "reboot*": "deny",
      "halt*": "deny",
      "poweroff*": "deny",
      "kill -9 *": "deny",
      "kill -KILL *": "deny",
      "kill -9": "deny",
      "git branch": "allow",
      "git remote": "allow",
      "git remote -v": "allow",
      "git stash list": "allow"
    },
    "external_directory": {
      "~/.ssh/**": "deny",
      "~/.gnupg/**": "deny",
      "~/.aws/**": "deny",
      "*": "ask"
    },
  },
  "agent": {
    "build": {
      "permission": {
        "edit": "allow"
      }
    },
    "plan": {
      "permission": {
        "edit": "deny",
      }
    }
  },
  "references": {
    "justin-practices": {
      "path": "~/.config/opencode/references",
      "description": "Justin's development practices and style guide"
    }
  },
  "lsp": {}
}
